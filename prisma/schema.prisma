generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth + User ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash — null for OAuth-only accounts
  role          String?   // 'musician' | 'manager' | 'hotel' | null = pending assignment
  isActive      Boolean   @default(true)
  phone         String?
  shows         String[]  @default([])
  hourlyRate    Float?
  // hotel-specific
  location      String?
  contactPerson String?
  hotelId       String?
  createdAt     DateTime  @default(now())

  hotel         Hotel?         @relation(fields: [hotelId], references: [id])
  notifications Notification[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ────────────────────────────────────────────────────────────

model Musician {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  phone      String
  shows      String[] @default([])
  hourlyRate Float
  isActive   Boolean  @default(true)
  avatar     String?
  createdAt  DateTime @default(now())

  events Event[]
}

model Hotel {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String
  location      String
  contactPerson String
  isActive      Boolean  @default(true)
  avatar        String?
  createdAt     DateTime @default(now())

  events Event[]
  users  User[]
}

model Event {
  id              String    @id @default(cuid())
  title           String
  description     String?
  date            String    // YYYY-MM-DD — kept as string to match domain type exactly
  time            String    // HH:MM
  durationMinutes Int
  hotel           String    // denormalized display name
  hotelId         String?
  musician        String?   // denormalized display name
  musicianId      String?
  status          String    @default("scheduled")
  checkedIn       Boolean   @default(false)
  checkInTime     DateTime?
  checkInPhoto    String?
  checkInLocation Json?     // { lat: Float, lng: Float }
  checkInComments String?
  createdAt       DateTime  @default(now())

  hotelRel      Hotel?         @relation(fields: [hotelId], references: [id])
  musicianRel   Musician?      @relation(fields: [musicianId], references: [id])
  notifications Notification[]
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  message    String
  type       String   // 'info' | 'warning' | 'success' | 'error'
  read       Boolean  @default(false)
  timestamp  DateTime @default(now())
  actionUrl  String?
  actionText String?
  eventId    String?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}
