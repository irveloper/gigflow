generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth + User ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash — null for OAuth-only accounts
  role           String?   // 'musician' | 'manager' | 'hotel' | 'superadmin' | null = pending assignment
  isActive       Boolean   @default(true)
  phone          String?
  instruments    String[]  @default([])
  styles         String[]  @default([])
  hourlyRate     Float?
  // hotel-specific
  location       String?
  contactPerson  String?
  hotelId        String?
  // org membership — null for pending users and superadmin
  organizationId String?
  // musician record link — set for users with role = 'musician'
  musicianId     String?   @unique
  createdAt      DateTime  @default(now())

  hotel         Hotel?         @relation(fields: [hotelId], references: [id])
  organization  Organization?  @relation(fields: [organizationId], references: [id])
  musician      Musician?      @relation(fields: [musicianId], references: [id])
  notifications       Notification[]
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organization (top-level SaaS tenant) ────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique  // URL-safe identifier, e.g. "sonidos-del-mar"
  status    String   @default("active")  // 'trialing' | 'active' | 'past_due' | 'suspended' | 'canceled'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  hotels          HotelOrganization[]
  musicians       MusicianOrganization[]
  bands           BandOrganization[]
  events          Event[]
  subscription    Subscription?
  musicianInvites MusicianInvite[]
}

model Subscription {
  id                   String    @id @default(cuid())
  organizationId       String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  // trialing | active | past_due | suspended | canceled
  status               String    @default("trialing")
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  seatLimit            Int       @default(3)
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// Explicit many-to-many: Hotel ↔ Organization
// Stores org-specific contact info alongside the shared hotel record
model HotelOrganization {
  hotelId        String
  organizationId String
  contactPerson  String?
  contactPhone   String?

  hotel        Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([hotelId, organizationId])
}

// Explicit many-to-many: Musician ↔ Organization
model MusicianOrganization {
  musicianId     String
  organizationId String

  musician     Musician     @relation(fields: [musicianId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([musicianId, organizationId])
}

// ─── Band ─────────────────────────────────────────────────────────────────────

model Band {
  id          String   @id @default(cuid())
  name        String
  description String?
  genre       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  members       BandMember[]
  organizations BandOrganization[]
  events        Event[]

  @@index([isActive])
}

// Explicit many-to-many: Musician ↔ Band
model BandMember {
  bandId     String
  musicianId String

  band     Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  musician Musician @relation(fields: [musicianId], references: [id], onDelete: Cascade)

  @@id([bandId, musicianId])
}

// Explicit many-to-many: Band ↔ Organization
model BandOrganization {
  bandId         String
  organizationId String

  band         Band         @relation(fields: [bandId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([bandId, organizationId])
}

// ─── Domain models ────────────────────────────────────────────────────────────

model Musician {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String
  instruments String[] @default([])
  styles      String[] @default([])
  hourlyRate  Float
  isActive    Boolean  @default(true)
  avatar      String?
  createdAt   DateTime @default(now())

  events        Event[]
  organizations MusicianOrganization[]
  bands         BandMember[]
  userAccount   User?
  invites       MusicianInvite[]

  @@index([isActive])
}

/// Portal invite sent by a manager to a musician.
/// Token is single-use and expires in 72 hours.
model MusicianInvite {
  id             String    @id @default(cuid())
  musicianId     String
  organizationId String
  email          String                   // musician email at invite time
  token          String    @unique
  expires        DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  musician     Musician     @relation(fields: [musicianId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([musicianId])
}

model Hotel {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String
  location      String
  contactPerson String
  isActive      Boolean  @default(true)
  avatar        String?
  createdAt     DateTime @default(now())

  events        Event[]
  users         User[]
  organizations HotelOrganization[]

  @@index([isActive])
}

model Event {
  id              String    @id @default(cuid())
  title           String
  description     String?
  date            String    // YYYY-MM-DD — kept as string to match domain type exactly
  time            String    // HH:MM
  durationMinutes Int
  hotel           String    // denormalized display name
  hotelId         String?
  musician        String?   // denormalized display name (solo)
  musicianId      String?
  band            String?   // denormalized display name (band booking)
  bandId          String?
  status          String    @default("scheduled")
  checkedIn       Boolean   @default(false)
  checkInTime     DateTime?
  checkInPhoto    String?
  checkInLocation Json?     // { lat: Float, lng: Float }
  checkInComments String?
  price           Float?    // null = no price set
  // org tenant — backfilled and non-nullable after migration 20260517000000
  organizationId  String
  createdAt       DateTime  @default(now())

  hotelRel      Hotel?         @relation(fields: [hotelId], references: [id])
  musicianRel   Musician?      @relation(fields: [musicianId], references: [id])
  bandRel       Band?          @relation(fields: [bandId], references: [id])
  organization  Organization   @relation(fields: [organizationId], references: [id])
  notifications Notification[]

  @@index([organizationId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginAuditLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  outcome   String   // success | failure
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

model EventAuditLog {
  id             String   @id @default(cuid())
  eventId        String
  organizationId String
  actorId        String?
  actorName      String
  actorRole      String   // "manager" | "musician" | "system"
  action         String   // EVENT_CREATED | MUSICIAN_ASSIGNED | ... (see EventAuditLogActionSchema)
  metadata       Json?
  timestamp      DateTime @default(now())

  @@index([eventId, timestamp(sort: Desc)])
  @@index([organizationId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  message    String
  type       String   // 'info' | 'warning' | 'success' | 'error'
  read       Boolean  @default(false)
  timestamp  DateTime @default(now())
  actionUrl  String?
  actionText String?
  eventId    String?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}
